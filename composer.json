{
    "name": "dschuppelius/php-config-toolkit",
    "description": "Ein Toolkit für JSON-basierte Konfigurationsverwaltung",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Joerg Schuppelius",
            "email": "info@schuppelius.org"
        }
    ],
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "ConfigToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3@dev",
        "laravel/pint": "^1.27",
        "phpstan/phpstan": "^2.1"
    },
    "require": {
        "php": ">=8.0 <8.6",
        "dschuppelius/php-error-toolkit": "^2.1"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint --test",
        "format:fix": "vendor/bin/pint",
        "lint": "vendor/bin/phpstan analyse --memory-limit=1G",
        "qa": [
            "@format",
            "@lint",
            "@test"
        ]
    }
}
